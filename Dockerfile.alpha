FROM golang:1.22-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOTOOLCHAIN=local go build -o /out/api ./cmd/api

FROM alpine:3.20

RUN apk add --no-cache ca-certificates && addgroup -S podcast && adduser -S -G podcast -u 10001 podcast
WORKDIR /app
COPY --from=build /out/api /app/api
COPY migrations /app/migrations
RUN chown -R podcast:podcast /app
USER 10001:10001

EXPOSE 8080
CMD ["/app/api"]
