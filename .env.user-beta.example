# Podcast Hub User Beta environment example.
# Placeholder values only. Do not commit real secrets, cookies, tokens, passwords, session data, or media.

APP_ENV=production
HTTP_ADDR=:8080
PUBLIC_BASE_URL=https://podcast-hub.example.invalid
FRONTEND_ORIGIN=https://podcast-hub.example.invalid

POSTGRES_DB=podcast_hub
POSTGRES_USER=podcast_hub
POSTGRES_PASSWORD=replace_with_database_password
DATABASE_URL=postgresql://podcast_hub:replace_with_database_password@postgres:5432/podcast_hub?sslmode=disable
REDIS_URL=redis://redis:6379/0

SESSION_COOKIE_NAME=podcast_hub_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=true
SESSION_TTL_SECONDS=1209600
SESSION_PEPPER=replace_with_random_session_pepper
AUTH_CODE_PEPPER=replace_with_random_auth_code_pepper
CSRF_HEADER_NAME=X-CSRF-Token

TURNSTILE_MODE=cloudflare
TURNSTILE_SECRET_KEY=replace_with_cloudflare_turnstile_secret
VITE_TURNSTILE_MODE=cloudflare
VITE_TURNSTILE_SITE_KEY=replace_with_cloudflare_turnstile_site_key
VITE_API_BASE_URL=https://podcast-hub.example.invalid

SMTP_HOST=smtp.example.invalid
SMTP_PORT=587
SMTP_USERNAME=replace_with_smtp_username
SMTP_PASSWORD=replace_with_smtp_password
SMTP_FROM=no-reply@example.invalid

SECRETS_MASTER_KEY=replace_with_32_byte_or_base64_key
CONNECTOR_PACKAGE_LOCAL_DIR=/data/connector-packages
IMPORT_ARTIFACT_STORE_DIR=/data/import-artifacts
STAGING_STORE_DIR=/data/staging
MEDIA_STORE_DIR=/data/private-media

RUNNER_MODE=disabled
RUNNER_TRUSTED_ADMIN_ENABLED=false
RUNNER_PYTHON_BASIC_IMAGE=python:3.12-alpine
RUNNER_PYTHON_TELEGRAM_IMAGE=python:3.12-alpine
RUNNER_WORKSPACE_ROOT=/workspace
RUNNER_UID=10001
RUNNER_GID=10001

BACKUP_DIR=./backups/user-beta
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
