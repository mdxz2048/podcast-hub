# Podcast Hub environment example
# Copy to .env only in a local environment. Do not commit .env.
# Values here are placeholders only. Do not put real secrets in this file.

APP_ENV=development
APP_URL=http://localhost:3000

# Database placeholder. Do not use real credentials here.
DATABASE_URL=postgresql://podcast_hub_user:change_me@localhost:5432/podcast_hub

# Session placeholder. Real values must be generated securely and kept out of Git.
SESSION_COOKIE_NAME=podcast_hub_session
SESSION_SECRET=change_me_use_a_secure_random_value
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Cloudflare Turnstile placeholders. Not connected in M0.
TURNSTILE_SITE_KEY=change_me
TURNSTILE_SECRET_KEY=change_me

# Email service placeholders. Not connected in M0.
MAIL_FROM=no-reply@example.invalid
MAIL_PROVIDER=disabled
MAIL_API_KEY=change_me

# Object storage placeholders. Not connected in M0.
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=podcast-hub-dev
OBJECT_STORAGE_ACCESS_KEY=change_me
OBJECT_STORAGE_SECRET_KEY=change_me

# Connector runner placeholders. Not connected in M0.
CONNECTOR_RUNNER_ENABLED=false
CONNECTOR_DEFAULT_TIMEOUT_SECONDS=900
CONNECTOR_MAX_OUTPUT_MB=2048

