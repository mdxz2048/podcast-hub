# Podcast Hub M1.0 environment example (placeholders only)
# Do not commit real secrets, tokens, passwords, or private endpoints.

# -------- Frontend (Vite) --------
VITE_API_BASE_URL=http://127.0.0.1:8080
VITE_TURNSTILE_MODE=mock
VITE_TURNSTILE_SITE_KEY=mock-site-key

# -------- Backend (Go API) --------
APP_ENV=development
HTTP_ADDR=:8080
FRONTEND_ORIGIN=http://127.0.0.1:5173

DATABASE_URL=postgresql://podcast_hub:change_me@127.0.0.1:5432/podcast_hub?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379/0

SESSION_COOKIE_NAME=podcast_hub_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=1209600
SESSION_PEPPER=change_me_session_pepper
AUTH_CODE_PEPPER=change_me_auth_code_pepper
CSRF_HEADER_NAME=X-CSRF-Token
SECRETS_MASTER_KEY=change_me_32_byte_secret_key_value!!

TURNSTILE_MODE=mock
TURNSTILE_SECRET_KEY=change_me_turnstile_secret

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.invalid

# -------- Local admin bootstrap (CLI only) --------
ADMIN_SEED_PASSWORD=change_me_admin_seed_password
