# Podcast Hub Alpha environment example (placeholders only)
# Do not commit real secrets, passwords, tokens, cookies, sessions, or media paths.

APP_ENV=development
HTTP_ADDR=:8080
FRONTEND_ORIGIN=http://127.0.0.1:4173

DATABASE_URL=postgresql://podcast_hub:change_me_alpha_password@postgres:5432/podcast_hub?sslmode=disable
REDIS_URL=redis://redis:6379/0

SESSION_COOKIE_NAME=podcast_hub_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=1209600
SESSION_PEPPER=replace_with_random_alpha_session_pepper
AUTH_CODE_PEPPER=replace_with_random_alpha_auth_code_pepper
CSRF_HEADER_NAME=X-CSRF-Token

TURNSTILE_MODE=mock
TURNSTILE_SECRET_KEY=replace_with_cloudflare_secret_when_enabled

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.invalid

CONNECTOR_PACKAGE_LOCAL_DIR=/data/connector-packages
SECRETS_MASTER_KEY=replace_with_32_byte_or_base64_key

RUNNER_MODE=disabled
RUNNER_PYTHON_BASIC_IMAGE=python:3.12-alpine
RUNNER_PYTHON_TELEGRAM_IMAGE=python:3.12-alpine
RUNNER_WORKSPACE_ROOT=.local/runner-workspaces

VITE_API_BASE_URL=http://127.0.0.1:8080
VITE_TURNSTILE_MODE=mock
VITE_TURNSTILE_SITE_KEY=mock-site-key

ADMIN_SEED_PASSWORD=replace_with_local_alpha_admin_password
